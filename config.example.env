# GraphMind v2 -- пример конфигурации
# Скопируйте в .env или загрузите через `set -a; source config.env; set +a` (bash) или `$env:VAR = "value"` (PowerShell).
# Полная схема: см. исходный код src/actors/config.rs

# === Режим запуска ===
# dev | production | test
# - dev:        по умолчанию; fail-fast на заглушках через Config::validate().
# - production: требует GRAPHMIND_LLM_PROVIDER + API-ключ (кроме openai-compatible без auth).
# - test:       отключает MCP-сервер (только нативный gRPC).
GRAPHMIND_MCP_MODE=dev

# GRAPHMIND_MCP_HTTP=false          # включить HTTP MCP-сервер (независимо от stdio MCP)
# GRAPHMIND_MCP_HTTP_ADDR=0.0.0.0:50052
# GRAPHMIND_GRPC_ADDR=0.0.0.0:50051  # установить для включения нативного gRPC-моста
# GRAPHMIND_NATIVE_MODE=false       # пока не используется main.rs (зарезервировано для V2.1)

# Тир-гейт open-core (MCP + Web UI). По умолчанию сервер обслуживает локальную
# машину/приватную сеть (Free — сколько угодно агентов на том же хосте), публичные
# источники отклоняются. Для командного/облачного тира — =true (пропускает все IP).
# Надёжный слой «только локально» — публикация порта на loopback (compose GM_BIND=127.0.0.1).
GRAPHMIND_ALLOW_EXTERNAL=false

# === Персистентность ===
# rocksdb (по умолчанию, production) | file (устарел) | memory (dev/test)
GRAPHMIND_PERSISTENCE=rocksdb
GRAPHMIND_DATA_DIR=./data

# Настройка RocksDB
# GRAPHMIND_ROCKSDB_COMPRESSION=true
# GRAPHMIND_ROCKSDB_PARALLELISM=0         # 0 = auto (num_cpus)
# GRAPHMIND_ROCKSDB_MEMTABLE_SIZE_MB=128
# GRAPHMIND_ROCKSDB_USE_FSYNC=false       # ДОЛЖНО быть true в production с RocksDB

# === Рабочая область ===
# GRAPHMIND_WORKSPACE=$(pwd)              # по умолчанию: cwd

# === Логи ===
# trace | debug | info | warn | error
GRAPHMIND_MCP_LOG_LEVEL=info
# GRAPHMIND_MCP_LOG_FILE=./logs/graphmind.log

# === LLM (V2.0) ===
# openai | openai-compatible | anthropic | openrouter | mock | disabled
# - openai-compatible: любой OpenAI-совместимый endpoint (LM Studio, Ollama, vLLM, локальный прокси)
# - mock:   для тестов, НЕ разрешен в production (Config::validate() завершится ошибкой)
# - disabled: нет вызовов LLM (нет OrchestratorActor.budget, нет PlanActor.decompose)
GRAPHMIND_LLM_PROVIDER=disabled

# GRAPHMIND_LLM_API_KEY=sk-...           # требуется в production для openai/anthropic/openrouter
# GRAPHMIND_LLM_MODEL=gpt-4o             # по умолчанию зависит от провайдера; ОБЯЗАТЕЛЬНА для openai-compatible
# GRAPHMIND_LLM_BASE_URL=https://api.openai.com/v1
# GRAPHMIND_LLM_BUDGET_PER_HOUR=1000      # 0 = безлимитно (только dev)
# GRAPHMIND_LLM_TIMEOUT_SECS=30

# --- примеры openai-compatible ---
# LM Studio:
#   GRAPHMIND_LLM_PROVIDER=openai-compatible
#   GRAPHMIND_LLM_BASE_URL=http://localhost:1234/v1
#   GRAPHMIND_LLM_MODEL=llama-3.1-70b-instruct
#   GRAPHMIND_LLM_API_KEY=                  # опционально (LM Studio не требует auth)
#
# Ollama (с OpenAI compat layer):
#   GRAPHMIND_LLM_PROVIDER=openai-compatible
#   GRAPHMIND_LLM_BASE_URL=http://localhost:11434/v1
#   GRAPHMIND_LLM_MODEL=qwen2.5-coder:32b
#   GRAPHMIND_LLM_API_KEY=ollama           # принимается любая непустая строка
#
# Внутренний vLLM:
#   GRAPHMIND_LLM_PROVIDER=openai-compatible
#   GRAPHMIND_LLM_BASE_URL=http://your-vllm-host:8000/v1
#   GRAPHMIND_LLM_MODEL=mistral-large-2
#   GRAPHMIND_LLM_API_KEY=your-key

# === Embeddings (V2.0) ===
# local | openai | disabled (fallback только по ключевым словам)
# GRAPHMIND_EMBEDDING_PROVIDER=disabled
# GRAPHMIND_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2   # по умолчанию для local (384 dim)
# GRAPHMIND_EMBEDDING_MODEL=text-embedding-3-small                    # по умолчанию для openai (1536 dim)
# GRAPHMIND_EMBEDDING_DIM=384
# GRAPHMIND_EMBEDDING_BATCH_SIZE=32
# GRAPHMIND_EMBEDDING_CACHE_ENABLED=true
# GRAPHMIND_EMBEDDING_CACHE_MAX_ENTRIES=10000
# GRAPHMIND_EMBEDDING_LOCAL_MODEL_PATH=~/.cache/huggingface/...
# GRAPHMIND_EMBEDDING_OFFLINE=false   # true = fail-fast, без сетевых загрузок
#
# --- Развязка endpoint эмбеддингов от LLM ---
# По умолчанию эмбеддинги берут base_url/api_key из GRAPHMIND_LLM_* (некоторые провайдеры отдают и chat,
# и embeddings). Если LLM и эмбеддинги на РАЗНЫХ серверах — задать отдельно.
# Пример: LLM на одном сервере, а эмбеддинги=локальная Ollama bge-m3:
#   GRAPHMIND_EMBEDDING_PROVIDER=openai
#   GRAPHMIND_EMBEDDING_MODEL=bge-m3
#   GRAPHMIND_EMBEDDING_DIM=1024
#   GRAPHMIND_EMBEDDING_BASE_URL=http://localhost:11434/v1   # переопределяет llm.base_url
#   GRAPHMIND_EMBEDDING_API_KEY=ollama                        # переопределяет llm.api_key

# === Очередь ===
# GRAPHMIND_QUEUE_INTERVAL_SECS=30
# GRAPHMIND_QUEUE_FILE_PATH=./data/pending_actions.json